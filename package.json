{
  "name": "linkedin-agent",
  "version": "1.0.0",
  "description": "LinkedIn Daily Posting Agent",
  "type": "module",
  "scripts": {
    "start": "tsx src/scheduler.ts",
    "server": "tsx watch src/server.ts",
    "build": "tsc",
    "lint": "eslint src",
    "dev": "concurrently \"npm run server\" \"npm --prefix client run dev\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@langchain/anthropic": "^1.5.0",
    "@langchain/core": "^1.1.48",
    "@langchain/google": "^0.1.12",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/openai": "^1.5.1",
    "@langchain/tavily": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.21.2",
    "node-cron": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/debug": "^4.1.13",
    "@types/express": "^4.17.21",
    "@types/ms": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/tough-cookie": "^4.0.5",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0"
  }
